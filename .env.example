# Application
NODE_ENV=development
PORT=3000
APP_NAME=site-safe-admin-panel
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mdm_admin_panel
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Passport
PASSPORT_JWT_SECRET=your-passport-jwt-secret-key

# Azure Services
AZURE_NOTIFICATION_HUB_NAME=your-hub-name
AZURE_NOTIFICATION_HUB_CONNECTION_STRING=Endpoint=sb://...
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...

# MicroMDM Configuration
MDM_BASE_URL=https://your-micromdm-server.com
MDM_API_KEY=your-micromdm-api-key

# Access Management System
ACCESS_MANAGEMENT_BASE_URL=https://access-management-api.com
ACCESS_MANAGEMENT_API_KEY=your-access-management-api-key

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001,https://your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional, for sessions/caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sentry (optional, error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Super Admin Initial Credentials
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-in-production
