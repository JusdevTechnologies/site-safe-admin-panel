# Application
NODE_ENV=development
PORT=3000
APP_NAME=site-safe-admin-panel
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mdm_admin_panel
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Passport
PASSPORT_JWT_SECRET=your-passport-jwt-secret-key

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# MicroMDM Configuration
MDM_BASE_URL=https://your-micromdm-server.com
MDM_API_KEY=your-micromdm-api-key

# NanoMDM Configuration
NANOMDM_BASE_URL=http://127.0.0.1:9000
NANOMDM_AUTH_TYPE=api_key
NANOMDM_API_KEY=your-nanomdm-api-key
NANOMDM_BEARER_TOKEN=
NANOMDM_TIMEOUT=30000

# Access Management System
ACCESS_MANAGEMENT_BASE_URL=https://access-management-api.com
ACCESS_MANAGEMENT_API_KEY=your-access-management-api-key

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3001,http://127.0.0.1:3001,https://your-domain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Super Admin Initial Credentials
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me-in-production

# ============================================
# Apple ADE (Automated Device Enrollment)
# ============================================

# Enable/disable ADE middleware
ADE_ENABLED=true

# API key for NanoDEP communication (X-ADE-API-Key header)
ADE_API_KEY=change-me-to-a-secure-ade-api-key

# Organization Branding
ADE_ORGANIZATION=Kokken Robotics and Consulting Solutions Pvt Ltd
ADE_ORGANIZATION_DISPLAY_NAME=Kokken Robotics
ADE_DEPARTMENT=IT
ADE_SUPPORT_EMAIL=support@kokkenrobotics.com
ADE_SUPPORT_PHONE=+1-555-0123
ADE_SUPPORT_CONTACT=IT Support

# Profile URLs
ADE_PROFILE_URL=https://mdm.kokkenrobotics.com/mdm
ADE_CHECKIN_URL=https://mdm.kokkenrobotics.com/checkin

# APNs
ADE_TOPIC=com.apple.mgmt.External.XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Anchor Certificates (reference only)
ADE_ANCHOR_CERTS=["XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"]

# Profile Defaults
ADE_PROFILE_VERSION=1
ADE_PROFILE_IDENTIFIER=com.kokken.mdm.enrollment

# Enrollment Behavior
ADE_IS_MANDATORY=true
ADE_SUPERVISED=true
ADE_ALLOW_PROFILE_REMOVAL=false
ADE_AWAIT_DEVICE_CONFIGURED=true
ADE_LANGUAGE=en
ADE_REGION=US

# Setup Assistant Panels to Skip (comma-separated)
ADE_SKIP_SETUP_ITEMS=AppleID,Appearance,Biometrics,Diagnostics,DisplayTone,FileVault,ICloudStorage,Location,Messages,Onboarding,Passcode,Payment,Privacy,Restore,ScreenTime,Siri,SoftwareUpdate,TOS,Welcome,Zoom

# Certificate Paths for Profile Generation
# Path to a PEM/DER file or directory containing root CA certificates
ADE_ROOT_CA_CERT_PATH=
# Path to a PKCS#12 file for identity certificate (optional for POC)
ADE_IDENTITY_CERT_PATH=
# Password for the PKCS#12 identity certificate
ADE_IDENTITY_CERT_PASSWORD=

# CMS (PKCS#7) Signing
# Enable/disable CMS signing of the .mobileconfig profile
ADE_SIGNING_ENABLED=false
# Path to the signing certificate PEM file (Apple MDM Vendor Cert)
ADE_SIGNING_CERT_PATH=
# Path to the signing private key PEM file
ADE_SIGNING_KEY_PATH=

# ABM Sync
ADE_ABM_SYNC_ENABLED=true
ADE_ABM_SYNC_INTERVAL=3600000
