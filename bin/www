#!/usr/bin/env node

require('dotenv').config();

const app = require('../src/app');
const environment = require('../config/environment');
const logger = require('../src/utils/logger');
const db = require('../src/models');
const SyncScheduler = require('../src/scheduler/SyncScheduler');

const port = environment.port;

// Sync database (for development; use migrations in production)
db.sequelize
  .sync({ alter: environment.nodeEnv === 'development' })
  .then(() => {
    logger.info('Database synced successfully');

    // Start server
    const server = app.listen(port, () => {
      logger.info(`${environment.appName} server is running on port ${port}`);
      logger.info(`Environment: ${environment.nodeEnv}`);
    });

    // Start background sync scheduler
    const scheduler = new SyncScheduler();
    scheduler.start();

    // Graceful shutdown
    const shutdown = async (signal) => {
      logger.info(`${signal} received, shutting down gracefully`);

      await scheduler.stop();

      server.close(() => {
        logger.info('Server closed');
        db.sequelize.close();
        process.exit(0);
      });
    };

    process.on('SIGINT', () => shutdown('SIGINT'));
    process.on('SIGTERM', () => shutdown('SIGTERM'));
  })
  .catch((err) => {
    logger.error('Error syncing database:', err);
    process.exit(1);
  });
